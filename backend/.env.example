PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/financial-screener?retryWrites=true&w=majority
FRONTEND_URL=http://localhost:5173
# SEC EDGAR requires a User-Agent identifying your app and contact email
SEC_USER_AGENT=FinancialScreener your@email.com
NODE_ENV=development
# Optional: Redis URL for search result caching (e.g. redis://localhost:6379 or Redis Cloud URL)
REDIS_URL=
